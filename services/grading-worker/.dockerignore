# Local dev environment / build artifacts — never ship in the build context
venv/
__pycache__/
*.pyc
*.pyo
tests/
scripts/
output/
*.log

# Secrets and local config
.env
.env*

# Tooling indexes / scan output
.codegraph/
.understand-anything/

# VCS / editor noise
.git/
.gitignore
.mypy_cache/
.pytest_cache/
