# Grading Worker Environment Variables
# HƯỚNG DẪN: Copy file này thành .env và điền giá trị thật vào (không commit .env!)

# Database
# URL-encode reserved characters in the password (@, /, :, %, etc.).
# Direct worker runs read DATABASE_URL. docker-compose.yml maps
# GRADING_DATABASE_URL into the worker's DATABASE_URL.
DATABASE_URL=postgresql://<DB_USER>:<URL_ENCODED_DB_PASSWORD>@postgres_db:5432/luve_database
GRADING_DATABASE_URL=postgresql://<DB_USER>:<URL_ENCODED_DB_PASSWORD>@postgres_db:5432/luve_database

# Redis
REDIS_URL=redis://redis:6379

# RabbitMQ
RABBITMQ_HOST=rabbitmq_queue
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# External APIs
LLM_PROVIDER=groq
GROQCLOUD_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=20.0

# Worker
# Grading provider: "fake" (default, offline dev grader) or "llm" (real Groq).
# To run REAL grading in dev: set GRADING_PROVIDER=llm, LLM_PROVIDER=groq, and a
# real GROQCLOUD_API_KEY above. Verify the live path once with the manual,
# dev-only smoke: `python scripts/groq_smoke.py` (makes one real Groq call; never
# run it in CI). Never commit secrets; there are no live-API tests in CI.
PYTHON_ENV=development
GRADING_PROVIDER=fake
GRADING_FAKE_FALLBACK=false
GRADING_MIN_STUDENT_WORDS=15
GRADING_MAX_ATTEMPTS=2
GRADING_RETRY_DELAY_SECONDS=1.0
# Delay (seconds) before requeue when terminal-state persistence fails (DB down),
# to avoid a hot redeliver loop. 0 disables the delay.
GRADING_REQUEUE_BACKOFF_SECONDS=5.0
GRADING_DB_POOL_SIZE=4
