# Grading Worker Environment Variables
# HƯỚNG DẪN: Copy file này thành .env và điền giá trị thật vào (không commit .env!)

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/luve_db

# Redis
REDIS_URL=redis://redis:6379

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# External APIs
OPENAI_API_KEY=

# Worker
PYTHON_ENV=development
WORKER_CONCURRENCY=4
