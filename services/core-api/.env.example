# 1. Database
DATABASE_URL=
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# 2. Redis
REDIS_URL=redis://localhost:6379

# 3. RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=
RABBITMQ_PASS=
ENABLE_LEGACY_WS_AUDIO=true
MAX_WEBRTC_SESSIONS=1

# 4. Security
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 5. External
OPENAI_API_KEY=
# Supported: gemini, groq. Set explicitly when more than one provider key exists.
LLM_PROVIDER=
LLM_TIMEOUT_SECONDS=20
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_SECONDS=20
GROQ_API_KEY=
GROQCLOUD_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
STT_MODEL_SIZE=small.en
STT_BEAM_SIZE=3
STT_PARTIAL_BEAM_SIZE=1
STT_FINAL_BEAM_SIZE=3
VAD_ENERGY_THRESHOLD_DB=-42
VAD_SILENCE_TIMEOUT_MS=650
VAD_PRE_ROLL_MS=250
STT_PARTIAL_EMIT_INTERVAL_MS=300
STT_PARTIAL_MIN_AUDIO_MS=450
STT_PARTIAL_WINDOW_MS=2200
STT_FINAL_MIN_AUDIO_MS=250
STT_INITIAL_PROMPT=This is a spoken English conversation between a learner and an AI tutor.
TTS_ENABLED=true
EDGE_TTS_VOICE=en-US-AnaNeural
TTS_PHRASE_MIN_CHARS=28
TTS_QUEUE_MAXSIZE=24
TTS_CHUNK_MS=120
TTS_FORCE_FLUSH_TIMEOUT_MS=600
LOCAL_TTS_ENABLED=false
PIPER_MODEL_PATH=
PIPER_SAMPLE_RATE=22050
