
# --- POSTGRESQL CONFIG ---
POSTGRES_USER=dat_admin
POSTGRES_PASSWORD=your_secure_db_password_here
POSTGRES_DB=luve_database
# Used by docker compose --profile app for grading_worker.
# URL-encode reserved password characters here instead of interpolating POSTGRES_PASSWORD.
GRADING_DATABASE_URL=postgresql://dat_admin:<URL_ENCODED_DB_PASSWORD>@postgres_db:5432/luve_database

# --- CORE-API / TEN GATEWAY CONFIG ---
# core_api and ten_gateway use SQLAlchemy async, so this MUST use the
# postgresql+asyncpg scheme (different from GRADING_DATABASE_URL above).
# URL-encode reserved characters in the password.
DATABASE_URL=postgresql+asyncpg://dat_admin:<URL_ENCODED_DB_PASSWORD>@postgres_db:5432/luve_database
# JWT signing key. core_api and ten_gateway MUST share the same value so
# tokens issued by the API validate at the gateway. Generate a strong random
# value, e.g.  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=<generate_a_strong_random_secret>
REDIS_URL=redis://redis_cache:6379

# --- RABBITMQ CONFIG ---
RABBITMQ_USER=admin
RABBITMQ_PASS=your_secure_rabbitmq_password_here

# --- STT / GATEWAY MODEL CONFIG ---
STT_LANGUAGE_MODE=forced_en
STT_MODEL_SIZE=small.en
STT_ENABLE_SECOND_PASS_VERIFICATION=false
# Runtime model/cache download location inside the container (mounted volume).
HF_HOME=/cache/huggingface

# --- LLM PROVIDER CONFIG (shared by gateway + grading_worker) ---
LLM_PROVIDER=groq
GROQCLOUD_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- CÁC THÔNG SỐ KHÁC (NẾU CÓ) ---
# Ví dụ: DOMAIN=luve.local
